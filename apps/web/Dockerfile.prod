FROM node:20-alpine AS build

WORKDIR /app

ARG VITE_API_URL=https://api-production.up.railway.app
ENV VITE_API_URL=${VITE_API_URL}

COPY package*.json ./
RUN npm install

COPY . .
RUN npm run build

FROM node:20-alpine

WORKDIR /app

RUN npm install -g serve

COPY --from=build /app/dist ./dist

EXPOSE 80

CMD ["serve", "-s", "dist", "-l", "0.0.0.0:80"]
